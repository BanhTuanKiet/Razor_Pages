@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    .dash-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }
    .stat-card {
        background: var(--color-background-secondary, #f5f4f0);
        border-radius: 8px;
        padding: 16px 20px;
    }
    .stat-label {
        font-size: 12px;
        font-family: 'DM Mono', monospace;
        color: var(--text-muted, #7a7670);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 8px;
    }
    .stat-value {
        font-size: 28px;
        font-weight: 600;
        color: var(--text, #1a1a18);
        font-family: 'DM Mono', monospace;
        line-height: 1;
    }
    .stat-sub {
        font-size: 12px;
        color: var(--text-muted, #7a7670);
        margin-top: 6px;
    }
    .nav-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
    }
    .nav-card {
        background: #ffffff;
        border: 1px solid #e8e4dc;
        border-radius: 8px;
        padding: 20px;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: border-color 0.15s, box-shadow 0.15s;
        cursor: pointer;
    }
    .nav-card:hover {
        border-color: #c9b99a;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        text-decoration: none;
        color: inherit;
    }
    .nav-card-icon {
        width: 36px; height: 36px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        flex-shrink: 0;
    }
    .nav-card-icon svg { width: 18px; height: 18px; }
    .nav-card-title {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a18;
    }
    .nav-card-desc {
        font-size: 12px;
        color: #7a7670;
        line-height: 1.5;
    }
    .nav-card-arrow {
        margin-top: auto;
        font-size: 12px;
        color: #c9b99a;
        font-family: 'DM Mono', monospace;
    }
    .section-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #7a7670;
        font-family: 'DM Mono', monospace;
        margin-bottom: 12px;
    }
    .activity-list {
        background: #ffffff;
        border: 1px solid #e8e4dc;
        border-radius: 8px;
        overflow: hidden;
    }
    .activity-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-bottom: 1px solid #f0ede8;
        font-size: 13px;
    }
    .activity-row:last-child { border-bottom: none; }
    .activity-dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .activity-text { color: #1a1a18; flex: 1; }
    .activity-time { color: #7a7670; font-family: 'DM Mono', monospace; font-size: 11px; }
</style>

<div style="margin-bottom: 24px;">
    <h1 style="font-size: 22px; font-weight: 600; color: #1a1a18; margin-bottom: 4px;">
        Dashboard
    </h1>
    <p style="font-size: 13px; color: #7a7670; font-family: 'DM Mono', monospace;">
        WebApplication1 · overview
    </p>
</div>

<!-- Stats -->
<div class="dash-grid">
    <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-value" id="statUsers">—</div>
        <div class="stat-sub">registered accounts</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total Items</div>
        <div class="stat-value" id="statItems">—</div>
        <div class="stat-sub">in catalogue</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total Orders</div>
        <div class="stat-value" id="statOrders">—</div>
        <div class="stat-sub">all time</div>
    </div>
</div>

<!-- Nav cards -->
<p class="section-label">Manage</p>
<div class="nav-cards">

    <a class="nav-card" href="/Users/Index">
        <div class="nav-card-icon" style="background:#f0ede8;">
            <svg viewBox="0 0 20 20" fill="#7a6f5e"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2h12z"/></svg>
        </div>
        <div class="nav-card-title">Users</div>
        <div class="nav-card-desc">Manage registered accounts, view orders per user.</div>
        <div class="nav-card-arrow">Go to users →</div>
    </a>

    <a class="nav-card" href="/Items/Index">
        <div class="nav-card-icon" style="background:#f0ede8;">
            <svg viewBox="0 0 20 20" fill="#7a6f5e"><path fill-rule="evenodd" d="M10 2a4 4 0 00-4 4v1H5a1 1 0 00-.994.89l-1 9A1 1 0 004 18h12a1 1 0 00.994-1.11l-1-9A1 1 0 0015 7h-1V6a4 4 0 00-4-4zm2 5V6a2 2 0 10-4 0v1h4zm-6 3a1 1 0 112 0 1 1 0 01-2 0zm7-1a1 1 0 100 2 1 1 0 000-2z" clip-rule="evenodd"/></svg>
        </div>
        <div class="nav-card-title">Items</div>
        <div class="nav-card-desc">Browse and update the product catalogue and stock.</div>
        <div class="nav-card-arrow">Go to items →</div>
    </a>

    <a class="nav-card" href="/Orders/Index">
        <div class="nav-card-icon" style="background:#f0ede8;">
            <svg viewBox="0 0 20 20" fill="#7a6f5e"><path d="M3 1a1 1 0 000 2h1.22l.305 1.222 1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/></svg>
        </div>
        <div class="nav-card-title">Orders</div>
        <div class="nav-card-desc">View all orders across users and inspect details.</div>
        <div class="nav-card-arrow">Go to orders →</div>
    </a>

    <a class="nav-card" href="/Privacy">
        <div class="nav-card-icon" style="background:#f0ede8;">
            <svg viewBox="0 0 20 20" fill="#7a6f5e"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        </div>
        <div class="nav-card-title">Privacy</div>
        <div class="nav-card-desc">Review the application privacy policy and terms.</div>
        <div class="nav-card-arrow">Read policy →</div>
    </a>

</div>

<!-- Recent activity placeholder -->
<p class="section-label">Recent activity</p>
<div class="activity-list">
    <div class="activity-row">
        <div class="activity-dot" style="background:#2e7d5e;"></div>
        <span class="activity-text">Application started successfully</span>
        <span class="activity-time">just now</span>
    </div>
    <div class="activity-row">
        <div class="activity-dot" style="background:#c9b99a;"></div>
        <span class="activity-text">Database connection established</span>
        <span class="activity-time">just now</span>
    </div>
    <div class="activity-row">
        <div class="activity-dot" style="background:#c9b99a;"></div>
        <span class="activity-text">Services registered and ready</span>
        <span class="activity-time">just now</span>
    </div>
</div>

<script>
    // Load stats từ các handler có sẵn
    Promise.allSettled([
        fetch('/Users?handler=Users',  { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ filters: {}, sorts: [], page: 0, pageSize: 9999 }) }),
        fetch('/Items?handler=All'),
        fetch('/Orders?handler=All')
    ]).then(async ([users, items, orders]) => {
        if (users.status === 'fulfilled') {
            const d = await users.value.json();
            const count = Array.isArray(d) ? d.length : (d.totalCount ?? d.data?.length ?? '—');
            document.getElementById('statUsers').textContent = count;
        }
        if (items.status === 'fulfilled') {
            const d = await items.value.json();
            document.getElementById('statItems').textContent = Array.isArray(d) ? d.length : '—';
        }
        if (orders.status === 'fulfilled') {
            const d = await orders.value.json();
            document.getElementById('statOrders').textContent = Array.isArray(d) ? d.length : '—';
        }
    });
</script>