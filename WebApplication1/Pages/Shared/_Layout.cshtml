<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@32.3.0/dist/ag-grid-community.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --sidebar-w:      220px;
            --bg:             #f5f4f0;
            --surface:        #ffffff;
            --sidebar-bg:     #1a1a18;
            --sidebar-border: rgba(255,255,255,0.06);
            --accent:         #c9b99a;
            --accent-dim:     #7a6f5e;
            --text:           #1a1a18;
            --text-muted:     #7a7670;
            --danger:         #c0392b;
            --success:        #2e7d5e;
            --warn:           #b07d2a;
            --blue:           #2563a8;
            --border:         #e8e4dc;
            --radius:         8px;
        }

        html, body {
            height: 100%;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            background: var(--bg);
            color: var(--text);
        }

        /* ── Shell ── */
        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            border-right: 1px solid var(--sidebar-border);
        }

        .sidebar-logo {
            padding: 22px 20px 18px;
            border-bottom: 1px solid var(--sidebar-border);
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .sidebar-logo-mark {
            width: 30px; height: 30px;
            background: var(--accent);
            border-radius: 6px;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .sidebar-logo-text {
            font-family: 'DM Mono', monospace;
            font-size: 13px;
            font-weight: 500;
            color: #e8e4dc;
            letter-spacing: 0.02em;
            line-height: 1.3;
        }

        .sidebar-logo-text span {
            display: block;
            font-size: 10px;
            color: var(--accent-dim);
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .sidebar-section-label {
            padding: 18px 20px 6px;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--accent-dim);
        }

        .sidebar-nav {
            padding: 4px 10px;
        }

        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: var(--radius);
            color: #a09890;
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            transition: background 0.15s, color 0.15s;
        }

        .sidebar-nav a:hover {
            background: rgba(255,255,255,0.06);
            color: #e8e4dc;
        }

        .sidebar-nav a.active {
            background: rgba(201,185,154,0.14);
            color: var(--accent);
        }

        .nav-icon {
            width: 17px; height: 17px;
            flex-shrink: 0;
            opacity: 0.5;
            transition: opacity 0.15s;
        }

        .sidebar-nav a:hover .nav-icon { opacity: 0.8; }
        .sidebar-nav a.active .nav-icon { opacity: 1; }

        .sidebar-divider {
            margin: 6px 16px;
            border: none;
            border-top: 1px solid var(--sidebar-border);
        }

        .sidebar-spacer { flex: 1; }

        .sidebar-footer {
            padding: 14px 18px;
            border-top: 1px solid var(--sidebar-border);
            display: flex;
            align-items: center;
            gap: 9px;
        }

        .sidebar-footer-dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            background: #4caf82;
            box-shadow: 0 0 5px #4caf8255;
            flex-shrink: 0;
        }

        .sidebar-footer-text {
            font-size: 11px;
            color: var(--accent-dim);
            font-family: 'DM Mono', monospace;
        }

        /* ── Main wrap ── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            height: 50px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 26px;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-breadcrumb {
            font-size: 12px;
            color: var(--text-muted);
            font-family: 'DM Mono', monospace;
        }

        .topbar-breadcrumb strong {
            color: var(--text);
            font-weight: 500;
        }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-chip {
            font-size: 11px;
            font-family: 'DM Mono', monospace;
            padding: 3px 10px;
            border-radius: 20px;
            background: #f0ede8;
            color: var(--text-muted);
            border: 1px solid #e0dbd4;
        }

        .page-content {
            flex: 1;
            padding: 28px;
        }

        /* ── Global buttons ── */
        .custom-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: var(--radius);
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            transition: opacity 0.15s, transform 0.1s;
            white-space: nowrap;
            line-height: 1;
        }

        .custom-btn:hover  { opacity: 0.85; }
        .custom-btn:active { transform: scale(0.97); }

        .btn-green  { background: var(--success); color: #fff; }
        .btn-red    { background: var(--danger);  color: #fff; }
        .btn-yellow { background: var(--warn);    color: #fff; }
        .btn-blue   { background: var(--blue);    color: #fff; }
        .btn-sm     { padding: 5px 11px; font-size: 12px; }

        .action-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            align-items: center;
        }

        /* ── Footer ── */
        .main-footer {
            padding: 13px 26px;
            border-top: 1px solid var(--border);
            font-size: 11.5px;
            color: var(--text-muted);
            font-family: 'DM Mono', monospace;
        }

        .main-footer a { color: var(--accent-dim); text-decoration: none; }
        .main-footer a:hover { color: var(--accent); }
    </style>
</head>

<body>
<div class="app-shell">

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="sidebar">

        <a class="sidebar-logo" asp-page="/Index">
            <div class="sidebar-logo-mark">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="1" y="1" width="6" height="6" rx="1.2" fill="#1a1a18"/>
                    <rect x="9" y="1" width="6" height="6" rx="1.2" fill="#1a1a18"/>
                    <rect x="1" y="9" width="6" height="6" rx="1.2" fill="#1a1a18"/>
                    <rect x="9" y="9" width="6" height="6" rx="1.2" fill="#1a1a18"/>
                </svg>
            </div>
            <div class="sidebar-logo-text">
                WebApp1
                <span>dashboard</span>
            </div>
        </a>

        <p class="sidebar-section-label">Manage</p>

        <nav class="sidebar-nav">

            <a asp-page="/Index">
                <!-- Home -->
                <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h4a1 1 0 001-1v-3h2v3a1 1 0 001 1h4a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
                </svg>
                Home
            </a>

            <a asp-page="/Users/Index">
                <!-- Users -->
                <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2h12zM18 14v2h2v-2a2 2 0 00-2-2v2zM2 14a2 2 0 00-2 2v2h2v-2z"/>
                </svg>
                Users
            </a>

            <a asp-page="/Items/Index">
                <!-- Items / Box -->
                <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 2a4 4 0 00-4 4v1H5a1 1 0 00-.994.89l-1 9A1 1 0 004 18h12a1 1 0 00.994-1.11l-1-9A1 1 0 0015 7h-1V6a4 4 0 00-4-4zm2 5V6a2 2 0 10-4 0v1h4zm-6 3a1 1 0 112 0 1 1 0 01-2 0zm7-1a1 1 0 100 2 1 1 0 000-2z" clip-rule="evenodd"/>
                </svg>
                Items
            </a>

            <a asp-page="/Orders/Index">
                <!-- Orders -->
                <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/>
                </svg>
                Orders
            </a>

        </nav>

        <hr class="sidebar-divider" />

        <nav class="sidebar-nav">
            <a asp-page="/Privacy">
                <!-- Privacy / Shield -->
                <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                Privacy
            </a>
        </nav>

        <div class="sidebar-spacer"></div>

        <div class="sidebar-footer">
            <div class="sidebar-footer-dot"></div>
            <div class="sidebar-footer-text">v1.0 · online</div>
        </div>

    </aside>

    <!-- ══════════ MAIN ══════════ -->
    <div class="main-wrap">

        <div class="topbar">
            <div class="topbar-breadcrumb">
                WebApp1 &nbsp;/&nbsp; <strong>@(ViewData["Title"] ?? "Home")</strong>
            </div>
            <div class="topbar-right">
                <span class="topbar-chip">ASP.NET Core Razor Pages</span>
            </div>
        </div>

        <div class="page-content">
            @RenderBody()
        </div>

        <footer class="main-footer">
            &copy; 2026 WebApplication1 &nbsp;·&nbsp;
            <a asp-page="/Privacy">Privacy Policy</a>
        </footer>

    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    // Auto-highlight active sidebar link
    (function () {
        const path = window.location.pathname.toLowerCase();
        document.querySelectorAll('.sidebar-nav a').forEach(function (a) {
            const href = (a.getAttribute('href') || '').toLowerCase();
            if (href === '/') {
                if (path === '/') a.classList.add('active');
            } else if (path.startsWith(href)) {
                a.classList.add('active');
            }
        });
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
